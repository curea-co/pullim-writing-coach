# /api/score 채점 — Anthropic Claude Haiku 4.5
ANTHROPIC_API_KEY=

# /try TokenGate 데모 접근 비밀번호 (서버 검증용 — /api/score가 x-demo-token 헤더와 비교)
DEMO_ACCESS_TOKEN=

# 선택: 빌드 시 클라이언트 번들에 inline돼 TokenGate가 자동 입력.
#   설정 시 사용자가 비밀번호 입력 없이 바로 채점 화면 진입.
#   값은 DEMO_ACCESS_TOKEN과 동일해야 함(서버 검증 통과).
#   주의: NEXT_PUBLIC_*는 누구나 devtools/JS 번들에서 볼 수 있음 → Anthropic 비용 폭주 위험.
#         반드시 Vercel rate limit·일일 사용량 상한·Anthropic 월 예산 알람과 함께 운영할 것.
NEXT_PUBLIC_DEMO_TOKEN=

# Sentry 에러 모니터링 (P0-#5, 출시 차단)
#   미설정 시 Sentry 통합 no-op — 데모/로컬 영향 없음.
#   EPO가 Sentry 가입 후 Vercel project env에 등록.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Sentry source map 업로드 (선택, 미설정 시 빌드 영향 없음)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Pullim 인증 백엔드(BFF 프록시 대상). dev: https://dev-api.pullim.ai
PULLIM_API_URL=https://dev-api.pullim.ai
# dev-api CSRF Origin 허용목록 값(BFF가 dev-api로 보내는 Origin). dev 확정: https://dev.pullim.ai
PULLIM_ORIGIN=https://dev.pullim.ai
