# /api/score 채점 — Anthropic Claude Haiku 4.5
ANTHROPIC_API_KEY=

# /try TokenGate 데모 접근 비밀번호 (서버 검증용 — /api/score가 x-demo-token 헤더와 비교)
DEMO_ACCESS_TOKEN=

# 선택: 빌드 시 클라이언트 번들에 inline돼 TokenGate가 자동 입력.
#   설정 시 사용자가 비밀번호 입력 없이 바로 채점 화면 진입.
#   값은 DEMO_ACCESS_TOKEN과 동일해야 함(서버 검증 통과).
#   주의: NEXT_PUBLIC_*는 누구나 devtools/JS 번들에서 볼 수 있음 → Anthropic 비용 폭주 위험.
#         반드시 Vercel rate limit·일일 사용량 상한·Anthropic 월 예산 알람과 함께 운영할 것.
NEXT_PUBLIC_DEMO_TOKEN=

# Sentry 에러 모니터링 (P0-#5, 출시 차단)
#   미설정 시 Sentry 통합 no-op — 데모/로컬 영향 없음.
#   EPO가 Sentry 가입 후 Vercel project env에 등록.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Sentry source map 업로드 (선택, 미설정 시 빌드 영향 없음)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# 인증 API 호스트 — 브라우저가 직접 호출(credentials:include, same-site 쿠키). 로컬 SSO 런북 기준.
#   useAuth가 `${API}/me`를 직접 GET. host-only 쿠키는 api 호스트로만 전송되므로 BFF가 아니라 직접 호출.
#   local = http://api.pullim.local:3000 · dev = https://dev-api.pullim.ai · prod = https://api.pullim.ai
#   ※ api(pullim-api) CORS_LOCAL_ORIGINS에 writing-coach origin(http://writing.pullim.local:3008, SSO)이 등재돼야 함.
#     로컬 호스트 SoT = pullim-api .claude/rules/local-ports.md (3008=라이팅코치=writing.pullim.local).
NEXT_PUBLIC_API_URL=https://dev-api.pullim.ai

# 로그인/로그아웃 UI(pullim-web). 헤더 로그인 버튼이 `${WEB}/login?next=<복귀 URL>`로 리다이렉트.
#   local = http://pullim.local:3001 · prod = https://pullim.ai
NEXT_PUBLIC_WEB_URL=https://pullim.ai

# 풀림 OS 허브(헤더 앱런처 목적지). OS 진입은 `/os` 경로(통합로그인 배포 문서 정본).
#   local = http://os.pullim.local:3001/os · dev = https://dev-os.pullim.ai/os · prod = https://os.pullim.ai/os
#   미설정 시 prod(os.pullim.ai/os) — 로컬 SSO에선 local 값을 설정해야 OS 버튼이 로컬로 이동.
NEXT_PUBLIC_OS_URL=https://os.pullim.ai/os

# per-user 계정 데이터 store — Supabase(관리형 Postgres) 연결 문자열(서버 전용).
#   /api/data/* 라우트가 app/lib/server/db.ts(postgres 드라이버)로 접속. 미설정 시 계정 store fail-closed(throw).
#   ⚠ 서버 전용 — NEXT_PUBLIC_ 프리픽스 금지(클라 번들 유출 방지). 자격증명·payload 로깅 금지.
#   ★ 앱 런타임은 Supabase Transaction pooler(Supavisor, 6543) 사용(서버리스 적합, db.ts가 prepare:false로 대응).
#     형식: postgresql://postgres.<ref>:PW@aws-0-<region>.pooler.supabase.com:6543/postgres
#     (마이그레이션은 Session pooler 5432 또는 Direct로.) 프로비저닝: docs/ops-db-provisioning.md
#   Production만 설정(Preview에 prod URL 금지 — 운영 데이터 접근). 표준 *.vercel.app 프리뷰는 SSO 쿠키
#   미도달로 게스트라 미설정 OK. .pullim.ai alias 프리뷰에서 계정 기능 테스트 시엔 별도 Preview DB 필요.
#   local 미설정(localStorage 폴백).
DATABASE_URL=

# (선택) 비prod 로컬 e2e용 데모 세션 sub — getSessionSub 데모 fallback 시 안정 user_id.
#   prod에선 무시(fail-closed). 미설정 시 "demo-sub".
DEMO_SESSION_SUB=
