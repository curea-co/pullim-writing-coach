# /api/score 채점 — Anthropic Claude Haiku 4.5
ANTHROPIC_API_KEY=

# /try TokenGate 데모 접근 비밀번호 (서버 검증용 — /api/score가 x-demo-token 헤더와 비교)
DEMO_ACCESS_TOKEN=

# 선택: 빌드 시 클라이언트 번들에 inline돼 TokenGate가 자동 입력.
#   설정 시 사용자가 비밀번호 입력 없이 바로 채점 화면 진입.
#   값은 DEMO_ACCESS_TOKEN과 동일해야 함(서버 검증 통과).
#   주의: NEXT_PUBLIC_*는 누구나 devtools/JS 번들에서 볼 수 있음 → Anthropic 비용 폭주 위험.
#         반드시 Vercel rate limit·일일 사용량 상한·Anthropic 월 예산 알람과 함께 운영할 것.
NEXT_PUBLIC_DEMO_TOKEN=

# ── pullim OS-SSO (로컬 서브도메인 SSO) ────────────────────────────────
#   writing-coach가 pullim-api(통합 IdP) 쿠키 세션을 소비하기 위한 설정.
#   로컬 SSO는 *.pullim.local 셋업 필요 — SoT: pullim-web 런북
#     docs/common/2026-06-22-local-pullim-local-sso/runbook.md
#   포트·호스트: 라이팅코치 = 3008, writing.pullim.local:3008 (pullim-api .claude/rules/local-ports.md)
#
# pullim-api(통합 IdP) origin. 로컬 SSO: http://api.pullim.local:3000 / prod: https://api.pullim.ai
NEXT_PUBLIC_PULLIM_API_URL=http://api.pullim.local:3000
# non-HttpOnly CSRF 쿠키 이름(env별: local-/dev-/prod-pullim-csrf)
NEXT_PUBLIC_PULLIM_CSRF_COOKIE=local-pullim-csrf
# 로그인 클릭 시 리다이렉트할 OS 진입(?next=로 복귀). 로컬: http://os.pullim.local:3001 / prod: https://os.pullim.ai
NEXT_PUBLIC_OS_URL=http://os.pullim.local:3001
# 로컬 dev 전용 — SSO 게이트 우회(1이면 세션 복원 없이 authenticated). 기본 off.
NEXT_PUBLIC_DEV_AUTH_BYPASS=

# Sentry 에러 모니터링 (P0-#5, 출시 차단)
#   미설정 시 Sentry 통합 no-op — 데모/로컬 영향 없음.
#   EPO가 Sentry 가입 후 Vercel project env에 등록.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Sentry source map 업로드 (선택, 미설정 시 빌드 영향 없음)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
